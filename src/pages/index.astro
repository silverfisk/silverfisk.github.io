---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = Array.from(await getCollection('posts'));

const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Home" currentPage="home">
  <div class="about-header">
    <img src="/images/avatar.jpg" alt="Tom" class="about-avatar" />
    <h1 class="about-name">Tom</h1>
    <p class="about-info">Platform engineer with 20 years relevant experiences in Linux systems and DevOps practices.</p>
    <div class="social-links">
      <a href="https://github.com/silverfisk/" aria-label="GitHub" target="_blank" rel="noopener">
        <i class="fa-brands fa-github"></i>
      </a>
      <a href="https://www.linkedin.com/in/tomeklof/" aria-label="LinkedIn" target="_blank" rel="noopener">
        <i class="fa-brands fa-linkedin"></i>
      </a>
    </div>
  </div>

  <section>
    <h2>Latest Posts</h2>
    <ul class="post-list">
      {sortedPosts.slice(0, 5).map(post => (
        <li>
          <span class="post-date">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          <h3 class="post-title"><a href={`/posts/${post.slug}/`}>{post.data.title}</a></h3>
          {post.data.description && <p class="post-excerpt">{post.data.description}</p>}
          {post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.map(tag => <span class="post-tag">{tag}</span>)}
            </div>
          )}
        </li>
      ))}
    </ul>
  </section>
</Layout>
